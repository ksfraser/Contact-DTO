{
    "name": "ksfraser/contact-dto",
    "description": "Shared Contact Data Transfer Object for bank import parsers and CRM integration",
    "type": "library",
    "license": "MIT",
    "keywords": ["contact", "dto", "bank-import", "crm"],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Kevin Fraser",
            "email": "kevin@example.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Ksfraser\\Contact\\": "src/Ksfraser/Contact/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ksfraser\\Contact\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^7.3 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    }
}
